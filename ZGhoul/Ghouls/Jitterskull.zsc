{
	Default
	{
		+BRIGHT
		SpriteAngle 180;
	}
	States
	{
	Spawn:
		G002 Z -1;
		Loop;
	}
}

class GS_JitterDome : GS_JitterPart
{
	States
	{
	Spawn:
		G002 B -1;
		Loop;
	}
}

class GS_JitterJaw : GS_JitterPart
{
	
	Default
	{
		+INTERPOLATEANGLES
		+ROLLCENTER
	}
	private void SetJitter(double _roll = 0, double xo = 0, double yo = 0, bool add = true)
	{
		if (add)
		{
			A_SetRoll(roll + _roll, SPF_INTERPOLATE);
			SpriteOffset += (xo, yo);
		}
		else
		{
			A_SetRoll(_roll, SPF_INTERPOLATE);
			A_SpriteOffset(xo, yo);
		}
	}
	
	private void ResetJitter()
	{
		A_SetRoll(0, SPF_INTERPOLATE);
		A_SpriteOffset(0, 0);
	}
	
	private void JitterJaw()
	{
		SetJitter(frandom[rng](-3, 3), frandom[rna](-2, 2), frandom[rnb](-2,2));
		double lim = 3.0;
		double ar = abs(roll);
		if (ar > lim)
		{
			
			double rc = ar % lim;
			if (roll < 0.0)	roll += rc * 2;
			else			roll -= rc * 2;
		}
		
		lim = 2.0;
		double o = SpriteOffset.X;
		double a = abs(o);
		if (o > lim)		SpriteOffset.X -= (a % lim) * 2.0;
		else if (o < -lim)	SpriteOffset.X += (a % lim) * 2.0;
		
		o = SpriteOffset.Y;
		if (o > lim)		SpriteOffset.Y -= (a % lim) * 2.0;
		else if (o < 0.0)	SpriteOffset.Y *= -1.0;
	}
	/*
	const ChewDistLarge = 6.0;
	const ChewTime = 12.0; // How long it takes to grind from one side to the next, must match tic count of longer shift!
	const ChewDistSmall = ChewDistLarge / ChewTime;
	*/
	const ChewDistSmall = 1;
	const ChewDistLarge = (ChewDistSmall * 22.0) / 4.0;
	States
	{
	Spawn:
	Idle:
		G002 A 1 ResetJitter();
		G002 A 1 JitterJaw();
		Wait;
	Lunge:
	Death:
		---- A 0 ResetJitter();
		---- AAA 1 SetJitter(0, 0, 7);
		---- A -1;
		Stop;
	Chew:
		
		---- A 1 SetJitter(-ChewDistSmall * 12.0, 0, 0, false);
		---- AAAAAAAAAAA 1 SetJitter(ChewDistSmall);
	Chewing:
		---- AAAAAAAAAAA 1 SetJitter(ChewDistSmall);		//longer shift
		---- AA 1 SetJitter(-ChewDistLarge, 0,  10);		//shorter
		---- AA 1 SetJitter(-ChewDistLarge, 0, -10);
		---- AAAAAAAAAAA 1 SetJitter(ChewDistSmall);
		/*
		---- AAAAAAAAAAAA 1 SetJitter(0, ChewDistSmall);	//longer shift
		---- AA 1 SetJitter(0, -ChewDistLarge, 10);			//shorter
		---- AA 1 SetJitter(0, -ChewDistLarge, -10);
		---- AAAAAAAAAAAA 1 SetJitter(0, ChewDistSmall);
		*/
		Loop;
		
	}
}

class GS_JitterSkull : GS_GhoulBase
{
	private Vector3 LaunchPos;
	Default
	{
		GS_GhoulBase.PainDelay 10;
		GS_GhoulBase.DmgThreshold 0;
		Monster;
		Health 1000;
		Scale 0.13;
		Height 70;
		Radius 25;
		Speed 15;
		PainChance 0;
		+DONTCORPSE
		+NOBLOCKMONST
		+QUICKTORETALIATE
		+NOICEDEATH
		+NORADIUSDMG
		+NOFEAR
		+DONTTHRUST
		+DONTMORPH
		+DONTBLAST
		+DONTGIB
		+NOBLOOD
		-ACTIVATEMCROSS
		+NOTRIGGER
		+NOTELEPORT
		+INTERPOLATEANGLES
		+NOTONAUTOMAP // The parts show up on the automap instead.
	//	+NOCLIP //disable after april fools
		MaxStepHeight 64;
		MaxDropoffHeight 64;
		BloodType "GS_JitterChip";
		SeeSound "Jitterskull/Taunt";
		PainSound "Jitterskull/Pain";
		DeathSound "Jitterskull/Death";
		/*
		// Internal Damagetypes
		DamageFactor "Sjas", 1;
		DamageFactor "CreeperBoo", 0.25;
		// Undead (AEoD)
		DamageFactor "AEPoison", 0.5;
		DamageFactor "AEBullet", 0.75;
		DamageFactor "Unholy", 0.5;
		DamageFactor "UnholyDisint", 0.5;
		DamageFactor "Holy", 2.0;
		DamageFactor "Disintegrate", 1.5;
		DamageFactor "AEMagic", 1.5;
		*/
		DamageType "Jitter";
		Obituary "%o was devoured by Jitterskull.";
		Tag "Jitterskull";
	}
	
