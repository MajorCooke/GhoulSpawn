/*------------------------------------------------------------------------------

Notes for addon makers:

- JSON is case sensitive with the variable NAMES, make sure they're all LOWER CASE.
Values stored after it are insensitive. I.e.

	"<variableName>":	<value>

variableNames must be in lower case!
------------------------------------------------------------------------------*/

{
	// IMPORTANT: Make sure to give your mod_id the same name as your package!
	// This will make it easier to debug if the JSON parser detects problems!
	// Do NOT set it as the same as GhoulSpawn!
	"mod_id": "GhoulSpawn",
	
	//--------------------------------------------------------------------------
	// Talents
	//--------------------------------------------------------------------------
	/*
	"categories":
	[
		{
			"category": "light",
		//	"desc": "$GSC_LIGHT_DESC", 		// generally assumes it's "$GSC_<descName>_DESC", only needed if it's not matching.
			"icon":	"LightCategory.png",	// Tries searching in Graphics/Upgrades/Icons first, and if not, uses the whole string.
			"pos": [ 0, 0 ]					// position of button on menu
		},
		{
			"category": "dark",
			"icon": "DarkCategory.png",
			"pos": [ 0, 0 ]
		},
		{
			"category": "chaos",
			"icon": "ChaosCategory.png",
			"pos": [ 0, 0 ]
		},
		{
			"category": "death",
			"icon": "DeathCategory.png",
			"pos": [ 0, 0 ]
		}
	],
	
	"upgrades":
	[
		{
			"name":	"",			// Name of upgrade
			"cate":	"",			// Category as defined above
			"desc":	"",			// Description
			"pos":	[0,0],		// Menu position in category
			"item":	"",			// item or behavior to give, if any (behaviors need a <Set/Get>Power() function)
			"levels": 5,		// max levels
			"cost": 1000,		// cost of aurora essence
			"reqs":				// required purchases to have first, can be with 
			[
				{ "upgrade": <string>, "amount": 1 }
				"nameOfUpgrade":	// defined this way, they are assumed to be needing just 1
				[	"nameOfUpgrade", 1	] // for specific level requirements
			]
		},
	],
	*/
	
	
	/*--------------------------------------------------------------------------
	Ghoul Definitions
	
	"():" denotes default value(s), i.e. "chance (256):"  means 256 is the default
	value if not specified.
	
	* actor: Name of the internal ghoul class inheriting from GS_GhoulBase.
	
	NOTE: By default, the following values will replace any other definitions
	found. If you append a + to the following variable names, they will add
	onto them instead. The one exception is with factors, those will always
	be replaced if duplicates are found. I.e. "factors+"
	
	Also supported is -, which will remove the indicated values.
	
	* factors: an OBJECT (NOT array!) whose variables are all doubles. 
	
		I.e.
		"creeperboo": 0.2,
		"jitter": 0.2
		would effectively be doing this in ZScript:
		DamageFactor "creeperboo", 0.2;
		DamageFactor "jitter", 0.2;
		
	* drops: String, object, or array of strings/objects of items to drop.
		The object properties are:
		
		* actor - Actor name to drop
		
		* count (1) - (Array of) int(s) (max 2 ints if array)
			How many of these to drop. 
		
		* chance (256)
			A chance in range of [0,256] to drop the item. Default: 256 (always)
			This does NOT influence the count amount, it affects the chance for
			the ENTIRE drop to happen at all. If more control is needed on chance,
			make multiple objects.
		
		Note that "drops-" will eliminate ALL of the items specified, i.e. if three
		megaspheres are set to drop originally, all will be removed.
		
		Alternatively, supplying "" or [] will remove all items.
		
	* weight (1): integer/int array (max of 2).
		Defines the spawn weight whenever the  ghoul is chosen to spawn.
		
		The weight system is effectively akin to RandomSpawner with dynamic chances.
		Each time a ghoul is selected, their weight is reset to this number, while
		all others gain weight to improve their odds for selection. Only ghouls with
		a weight > 0 are considered for selection, others must wait for theirs to
		increase above that threshold. This means the system operates on an (n + 1)
		notation; "weight": -5 means 6 turns will be skipped, effectively.
	--------------------------------------------------------------------------*/

	"ghouls":
	[
		{
			"actor":		"GS_Sjas", 	// Actor name
			"factors":
			{
				"creeperboo":	0.2,
				"jitter":		0.2
			},
			"drops":		"GS_DefaultItems"
		},
		{
			"actor": 		"GS_Jitterskull",
			"factors":
			{
				"creeperboo":	0.25
			},
			"drops":		"GS_DefaultItems"
		},
		{
			"actor": 		"GS_Creeper",
			"factors":
			{
				"sjas":			0.6,
				"jitter":		0.25
			},
			"weight":		-5, // n + 1 notation, requiring six different ghouls to spawn
			"drops":		"GS_DefaultItems"
			
		},
		{
			"actor": 		"GS_Choke",
			"factors":
			{
				"sjas":			0.4,
				"jitter":		0.3,
				"creeperboo":	0.25
			},
			"drops":		"GS_DefaultItems"
		},
		{
			"actor": 		"GS_Frostbite",
			"drops":		"GS_DefaultItems"
		},
		{
			"actor":		"GS_Misty",
			"drops":		"GS_DefaultItems"
		},
		{
			"actor":		"GS_Clowny",
			"drops":		"GS_DefaultItems"
		},
		{
			"actor":		"GS_SoulHarvester",
			"drops":		"GS_DefaultItems"
		},
		{
			"actor":		"GS_Yurei",
			"drops":		"GS_DefaultItems"
		},
	],
	
	/*--------------------------------------------------------------------------
	Trait Data
	
	* langstr - The LANGUAGE lump string to look up, which will cover name, icon,
		desc and long. Take note how the traits only have GST_<TraitName> WITHOUT
		the ending suffix of _<NAME/DESC/ICON/LONG>. If those vars are present,
		they will override what's found by the langstr, even if blank! Requires
		a string with _BASE defined in order to work.
		
	* base - Base name of the upgrade to use internally. 
		langstr uses the part after 'GST_' for this variable.
	
	* name - Nice name used for displaying in the codex.
		langstr uses the value of 'GST_<TraitName>_NAME' for this variable.
		
	* desc - Synopsis of the trait.
	
	* long - Expanded definition for reading in the codex.
	
	* rank - Can be 'normal' (default), 'uncommon', 'rare' or 'legendary'.
		Alternatively can supply a number between [0,3] respectively.
		
	* levelreq - An array of 1 or 2 numbers, which defines the level range the
		ghoul must be within to have a chance at receiving this trait. Default is
		[0].
		Accepted syntax:
		[min] or [min,max]
		
	* maxpower - Maximum amount of times this trait can be selected again. Same
		as investing more points in a talent tree for a stronger effect.
		
	* items - String array of inventory actors OR behaviors to give. These are
		delivered IN ORDER by the way they're listed. (Reminder: Behaviors call
		Initialize() if the actor lacks it, Reinitialize() otherwise.)
		This is done each time the trait is given.
		
		**NOTE**
		Traits cannot be stripped and ghouls will have them until killed, but
		the items/behaviors can be removed. Use inventory/behaviors for one-off 
		events, etc.
		
	* classes - String array of whitelisted actor classes. Leave blank or don't
		specify to allow all to receive it. Alternatively, "remove:<class>" or 
		"remove:all" can be used to override previous definitions, useful for
		addon developers. 
		
		**NOTE** 
		This is processed in order, top to bottom!
		
	* traitreq - Object array of traits needed to be applicable.
		* name - Base name of the trait (not the nice name)
		* power - Int variable/array similar to 'levelreq'. If set to 0, means
			the trait is cannot apply if the listed one is present. Defaults to 1.
	--------------------------------------------------------------------------*/
	
	"traits":
	[
		// All default values are seen with each definition.
		{
			
			"langstr": "",
			"base": "",
			"name": "",
			"icon": "",
			"desc": "",
			"long": "",
			"rank": "Normal",
			"levelreq": [0],
			"maxpower": 1,
			"items":
			[
				
			],
			"classes": // list of applicable classes. If left blank, applies to all of them.
			[
			],
			"traitreq":
			[
			]
			
		},
	],
	
}